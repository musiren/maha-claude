#!/bin/bash
# pre-commit: Run pytest before allowing a commit.
#
# Each component directory (client/, gateway/, etc.) is tested independently
# with its own PYTHONPATH to avoid module name collisions.
#
# - No test files found  → warn and allow commit
# - Test files found, all pass  → allow commit
# - Test files found, any fail  → block commit (exit 1)

REPO_ROOT="$(git rev-parse --show-toplevel)"
PYTEST_BIN="${PYTEST_BIN:-}"

# Locate pytest.
if [[ -z "$PYTEST_BIN" ]]; then
    if [[ -x "$REPO_ROOT/.venv/bin/pytest" ]]; then
        PYTEST_BIN="$REPO_ROOT/.venv/bin/pytest"
    elif [[ -x "/root/.local/bin/pytest" ]]; then
        PYTEST_BIN="/root/.local/bin/pytest"
    elif command -v pytest >/dev/null 2>&1; then
        PYTEST_BIN="pytest"
    fi
fi

if [[ -z "$PYTEST_BIN" ]]; then
    echo "[pre-commit] WARNING: pytest not found. Skipping test check." >&2
    echo "[pre-commit] Install with: pip install pytest" >&2
    exit 0
fi

# Find component directories that contain <component>/tests/test_*.py.
# Pattern: REPO_ROOT/<component>/tests/test_*.py  (depth 3 from root)
mapfile -t COMPONENT_DIRS < <(
    find "$REPO_ROOT" -mindepth 3 -maxdepth 3 \
        -not -path '*/.git/*' \
        -not -path '*/__pycache__/*' \
        \( -name 'test_*.py' -o -name '*_test.py' \) \
        | sed 's|/tests/[^/]*$||' \
        | sort -u
)

if [[ ${#COMPONENT_DIRS[@]} -eq 0 ]]; then
    echo "[pre-commit] WARNING: No test files found. Skipping pytest." >&2
    echo "[pre-commit] Add tests to <component>/tests/test_*.py to enable enforcement." >&2
    exit 0
fi

FAILED=0

for COMPONENT_DIR in "${COMPONENT_DIRS[@]}"; do
    COMPONENT_NAME="$(basename "$COMPONENT_DIR")"
    TEST_DIR="$COMPONENT_DIR/tests"

    if [[ ! -d "$TEST_DIR" ]]; then
        continue
    fi

    echo "[pre-commit] Testing $COMPONENT_NAME/ ..." >&2

    if PYTHONPATH="$COMPONENT_DIR" "$PYTEST_BIN" --tb=short -q "$TEST_DIR"; then
        echo "[pre-commit] $COMPONENT_NAME: all tests passed." >&2
    else
        echo "[pre-commit] $COMPONENT_NAME: TESTS FAILED." >&2
        FAILED=1
    fi
done

if [[ $FAILED -ne 0 ]]; then
    echo "" >&2
    echo "[pre-commit] COMMIT BLOCKED: Fix test failures before committing." >&2
    exit 1
fi

exit 0
